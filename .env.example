# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control!
# =============================================================================

# =============================================================================
# DATABASE (SQLite — 별도 설치 없이 파일 DB로 바로 실행)
# =============================================================================
# 이 값 그대로 두면 됩니다. prisma/dev.db 파일이 자동 생성됩니다.
DATABASE_URL="file:./dev.db"

# =============================================================================
# AUTHENTICATION (NextAuth.js)
# =============================================================================
# 교육용 기본값 — 실습은 이대로 사용 가능. 운영 시 openssl rand -base64 32 로 교체.
NEXTAUTH_SECRET="dev-secret-for-local-testing-change-in-production"
NEXTAUTH_URL="http://localhost:3000"
ADMIN_EMAIL="admin@example.com"
NEXT_PUBLIC_APP_NAME="세컨팀 커머스"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OAuth Providers (Optional)
# Google OAuth
# Get credentials from: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth
# Get credentials from: https://github.com/settings/developers
# GITHUB_ID="your-github-client-id"
# GITHUB_SECRET="your-github-client-secret"

# =============================================================================
# PAYMENTS (토스페이먼츠)
# =============================================================================
# 아래는 토스페이먼츠가 문서용으로 공개한 테스트 키입니다.
# 이 값 그대로 두면 실제 결제 없이(차감 없이) 결제 흐름을 실습할 수 있습니다.
# 실 운영 시 https://developers.tosspayments.com 에서 발급받은 키로 교체하세요.
NEXT_PUBLIC_TOSS_CLIENT_KEY="test_gck_docs_Ovk5rk1EwkEbP0W43n07xlzm"
TOSS_SECRET_KEY="test_gsk_docs_OaPz8L5KdmQXkzRz3y47BMw6"

# =============================================================================
# EMAIL SERVICE (Resend)
# =============================================================================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY="re_..."
FROM_EMAIL="noreply@yourdomain.com"

# =============================================================================
# FILE STORAGE (Choose ONE provider)
# =============================================================================

# Option 1: AWS S3
# Get credentials from: https://console.aws.amazon.com/iam/
# AWS_ACCESS_KEY_ID="your-aws-access-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
# AWS_S3_BUCKET_NAME="your-bucket-name"
# AWS_REGION="us-east-1"

# Option 2: Cloudflare R2
# Get credentials from: https://dash.cloudflare.com/
# CLOUDFLARE_R2_ACCESS_KEY_ID="your-r2-access-key"
# CLOUDFLARE_R2_SECRET_ACCESS_KEY="your-r2-secret-key"
# CLOUDFLARE_R2_BUCKET_NAME="your-bucket-name"
# CLOUDFLARE_R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"

# Option 3: Supabase Storage
# Get credentials from: https://app.supabase.com/project/_/settings/api
# SUPABASE_URL="https://your-project.supabase.co"
# SUPABASE_ANON_KEY="your-supabase-anon-key"
# SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Public-facing app settings (NEXT_PUBLIC_* are exposed to the browser)
NEXT_PUBLIC_APP_NAME="E-Commerce Store"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin user email (used for initial setup and admin role assignment)
ADMIN_EMAIL="admin@yourdomain.com"

# Environment mode
NODE_ENV="development"

# =============================================================================
# ANALYTICS & MONITORING (Optional)
# =============================================================================
# Google Analytics
# Get your measurement ID from: https://analytics.google.com/
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID="GA_MEASUREMENT_ID"

# Vercel Analytics
# NEXT_PUBLIC_VERCEL_ANALYTICS="true"

# =============================================================================
# REDIS CACHE (Optional - for production)
# =============================================================================
# Redis connection string for caching and session storage
# Format: redis://username:password@host:port
# REDIS_URL="redis://localhost:6379"

# =============================================================================
# LOGGING & DEBUGGING (Optional)
# =============================================================================
# Log level: debug, info, warn, error
# LOG_LEVEL="info"

# Enable debug mode (shows detailed error messages)
# DEBUG="false"